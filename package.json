{
  "name": "postdesk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:demo": "vite build --mode demo && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit && oxlint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:demo": "DOTENV_CONFIG_PATH=.env.demo drizzle-kit push",
    "db:migrate": "tsx src/db/setup.ts",
    "db:migrate:noseed": "tsx src/db/setup.ts --no-seed",
    "db:migrate:demo": "DOTENV_CONFIG_PATH=.env.demo tsx src/db/setup.ts",
    "db:migrate:demo:noseed": "DOTENV_CONFIG_PATH=.env.demo tsx src/db/setup.ts --no-seed",
    "db:studio": "drizzle-kit studio",
    "db:setup": "tsx src/db/setup.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^2.4.0",
    "@hono/node-server": "^2.0.4",
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "ts-results-es": "^7.0.0",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.4.1",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
